# The AI agent's model access (see docs/AGENT.md, phase 1).
#
# Copy this file to `.env` and fill in AGENT_API_KEY. `.env` is gitignored and read only
# server-side by the Vite dev proxy at /api/agent/chat - it never reaches the browser
# bundle. Restart `yarn dev` after editing.

# Your model API key. For Google Gemini, create one at https://aistudio.google.com/apikey
AGENT_API_KEY=

# OpenAI-compatible base URL for the provider. The default targets Gemini's
# OpenAI-compatible endpoint; point it at OpenAI / Groq / a local Ollama to switch.
AGENT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# The model to use. gemini-2.5-flash has free-tier quota; gemini-2.0-flash can report a
# zero free-tier limit on some projects. Any OpenAI-compatible model id works.
AGENT_MODEL=gemini-2.5-flash
