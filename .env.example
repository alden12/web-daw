# Copy to .env and adjust. .env is gitignored; .env.example is the committed template.

# --- Sync server (Node/Hono + Postgres) ---
# Postgres connection the API server + drizzle-kit use. Matches docker-compose.yml.
DATABASE_URL=postgres://webdaw:webdaw@localhost:5432/webdaw
# Port the API server listens on.
API_PORT=5170
# Shared bearer token gating the API. Leave BLANK for open local dev; set a value
# (and match VITE_DAW_API_TOKEN) before exposing the server anywhere.
DAW_API_TOKEN=
# Allowed CORS origin(s), comma-separated. Unset defaults to "*" (fine for local dev, where
# the app runs on :5155 and the API on :5170). Narrow to the app's origin on deploy.
DAW_CORS_ORIGIN=

# Overrides for docker-compose.yml (optional; defaults shown).
# POSTGRES_USER=webdaw
# POSTGRES_PASSWORD=webdaw
# POSTGRES_DB=webdaw
# POSTGRES_PORT=5432

# --- Client (Vite) ---
# Point the app at the sync server. Leave UNSET to run local-only (OPFS in the
# browser); set it to switch the project store to the remote backend.
VITE_DAW_API_URL=http://localhost:5170
VITE_DAW_API_TOKEN=
