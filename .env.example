# Copy to .env and adjust. .env is gitignored; .env.example is the committed template.
#
# Deploying (Fly.io, single origin) - see docs/DEPLOY.md. Two kinds of config:
#   - Build-time (baked into the client by Vite): VITE_DAW_API_URL, VITE_SUPABASE_URL,
#     VITE_SUPABASE_ANON_KEY. Passed as `fly deploy --build-arg VITE_...=...`. In single-origin,
#     VITE_DAW_API_URL is the deploy origin itself, e.g. https://web-daw.fly.dev.
#   - Runtime (server env / Fly secrets): DATABASE_URL (Neon), SUPABASE_JWKS_URL, SUPABASE_JWT_ISSUER,
#     API_PORT, NODE_ENV. Set via `fly secrets set ...` (fly.toml sets API_PORT/NODE_ENV).

# --- Sync server (Node/Hono + Postgres) ---
# Postgres connection the API server + drizzle-kit use. Matches docker-compose.yml.
DATABASE_URL=postgres://webdaw:webdaw@localhost:5432/webdaw
# Port the API server listens on.
API_PORT=5170
# Allowed CORS origin(s), comma-separated. Unset defaults to "*" (fine for local dev, where
# the app runs on :5155 and the API on :5170). Narrow to the app's origin on deploy.
DAW_CORS_ORIGIN=

# --- Real auth (Supabase) ---
# When BOTH are set, the API verifies a Supabase JWT (JWKS, asymmetric signing keys) on every request +
# WS upgrade and the principal is the token's user. Leave unset for dev-stub mode (open, a single "local"
# owner) - local dev only; always set these in any deployed/exposed environment. From your Supabase project:
#   JWKS:   https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
#   Issuer: https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=

# Overrides for docker-compose.yml (optional; defaults shown).
# POSTGRES_USER=webdaw
# POSTGRES_PASSWORD=webdaw
# POSTGRES_DB=webdaw
# POSTGRES_PORT=5432

# --- Client (Vite) ---
# Point the app at the sync server. Leave UNSET to run local-only (OPFS in the
# browser); set it to switch the project store to the remote backend.
VITE_DAW_API_URL=http://localhost:5170
# Supabase auth (client). Set BOTH to show the login gate and send the signed-in user's JWT on every
# request; pairs with the server's SUPABASE_JWKS_URL / SUPABASE_JWT_ISSUER. Leave unset for dev-stub
# mode (no login, open). The anon key is public (safe to ship in the client bundle).
#   URL:      https://<project-ref>.supabase.co
#   Anon key: Supabase dashboard -> Project Settings -> API -> anon/public key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
