# Copy to .env and adjust. .env is gitignored; .env.example is the committed template.

# --- Sync server (Node/Hono + Postgres) ---
# Postgres connection the API server + drizzle-kit use. Matches docker-compose.yml.
DATABASE_URL=postgres://webdaw:webdaw@localhost:5432/webdaw
# Port the API server listens on.
API_PORT=5170
# Shared bearer token gating the API (dev-stub auth). Leave BLANK for open local dev; set a value
# (and match VITE_DAW_API_TOKEN) before exposing the server anywhere. Ignored once real auth below is on.
DAW_API_TOKEN=
# Allowed CORS origin(s), comma-separated. Unset defaults to "*" (fine for local dev, where
# the app runs on :5155 and the API on :5170). Narrow to the app's origin on deploy.
DAW_CORS_ORIGIN=

# --- Real auth (Supabase) ---
# When BOTH are set, the API verifies a Supabase JWT (JWKS, asymmetric signing keys) on every request +
# WS upgrade and the principal is the token's user - replacing the shared DAW_API_TOKEN gate. Leave unset
# for dev-stub mode (shared token + a single "local" owner). Values come from your Supabase project:
#   JWKS:   https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
#   Issuer: https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=

# Overrides for docker-compose.yml (optional; defaults shown).
# POSTGRES_USER=webdaw
# POSTGRES_PASSWORD=webdaw
# POSTGRES_DB=webdaw
# POSTGRES_PORT=5432

# --- Client (Vite) ---
# Point the app at the sync server. Leave UNSET to run local-only (OPFS in the
# browser); set it to switch the project store to the remote backend.
VITE_DAW_API_URL=http://localhost:5170
VITE_DAW_API_TOKEN=
# Supabase auth (client). Set BOTH to show the login gate and send the signed-in user's token instead of
# the static one above; pairs with the server's SUPABASE_JWKS_URL / SUPABASE_JWT_ISSUER. Leave unset for
# dev-stub auth (no login). The anon key is public (safe to ship in the client bundle).
#   URL:      https://<project-ref>.supabase.co
#   Anon key: Supabase dashboard -> Project Settings -> API -> anon/public key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
