# Test / e2e mode (`vite --mode test`). Committed and deliberately non-secret: it blanks the auth +
# remote-backend vars so a local `.env` (which turns the Supabase login gate on) is OVERRIDDEN when
# Playwright starts the dev server. Vite loads `.env.test` after `.env` in this mode, and later files
# win, so these empty values take precedence. This is why `yarn test:e2e` no longer needs `.env` moved
# aside. Empty => authEnabled is false (login gate off) and storage falls back to OPFS (no remote sync).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_DAW_API_URL=
